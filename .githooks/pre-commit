#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

echo "pre-commit: hizli kontroller"

while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  [[ ! -f "$file" ]] && continue

  if grep -nE '^(<<<<<<<|=======|>>>>>>>)' "$file" >/dev/null; then
    echo "Conflict marker bulundu: $file" >&2
    exit 1
  fi

  if [[ "$file" == *.sh ]]; then
    bash -n "$file"
  fi
done <<< "$STAGED_FILES"
