{
  "name": "horsegallop-backend",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test lib/__tests__/*.test.js",
    "seed": "npm run build && node lib/scripts/seed.js",
    "serve": "firebase emulators:start --only functions",
    "serve:web": "firebase emulators:start --only hosting",
    "deploy": "npm run build && firebase deploy --only functions",
    "deploy:web": "firebase deploy --only hosting",
    "deploy:all": "npm run build && firebase deploy --only functions,hosting",
    "lint": "echo 'No lint configured'"
  },
  "dependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node-fetch": "^2.6.13",
    "cheerio": "^1.2.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.6.3"
  }
}
