<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!--
      Jockey on horse, side view (horse faces right).
      Horse body: horizontal capsule
      Horse head/neck: extending upper-right
      Rider: small head circle + leaning torso on top of horse
      Legs: four short sticks
    -->
    <!-- Horse body -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M 4,14 C 4,10 7,9 13,9 C 19,9 22,11 22,14
            C 22,17 19,18 13,18 C 7,18 4,17 4,14 Z"/>
    <!-- Horse neck + head (right, upper) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M 22,12 C 22,9 21,7 20,7
            C 19,7 19,9 20,10 C 21,11 22,11 22,12 Z"/>
    <!-- Horse tail (left, stroke) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FF000000"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M 4,13 C 3,11 2,10 2,8"/>
    <!-- Rider head (circle at top-center of horse) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="M 13,7 m -2,0 a 2,2 0 1,0 4,0 a 2,2 0 1,0 -4,0"/>
    <!-- Rider torso (leaning slightly forward) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FF000000"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M 13,9 L 11.5,13"/>
    <!-- Horse legs (four sticks) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FF000000"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M 7,18 L 6,23 M 11,18 L 10,23 M 16,18 L 16,23 M 19,18 L 20,23"/>
</vector>
