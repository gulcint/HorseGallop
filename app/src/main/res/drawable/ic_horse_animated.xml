<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:width="200dp"
            android:height="200dp"
            android:viewportWidth="200"
            android:viewportHeight="200">
            <group android:name="horse">
                <path
                    android:name="horse_body"
                    android:fillColor="#8B4513"
                    android:pathData="M100,60 C120,60 140,70 140,90 L140,120 C140,135 125,145 100,145 C75,145 60,135 60,120 L60,90 C60,70 80,60 100,60 Z" />
                <path
                    android:name="horse_head"
                    android:fillColor="#8B4513"
                    android:pathData="M140,70 L160,55 C165,52 168,55 168,60 L168,75 C168,80 165,83 160,80 L140,70 Z" />
                <path
                    android:name="horse_legs"
                    android:fillColor="#654321"
                    android:pathData="M75,145 L75,175 M85,145 L85,175 M115,145 L115,175 M125,145 L125,175"
                    android:strokeWidth="6"
                    android:strokeColor="#654321" />
                <path
                    android:name="horse_tail"
                    android:fillColor="none"
                    android:pathData="M60,100 Q45,95 50,110 Q55,120 45,125"
                    android:strokeWidth="4"
                    android:strokeColor="#654321" />
            </group>
        </vector>
    </aapt:attr>
    <target android:name="horse">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="1000"
                    android:propertyName="scaleX"
                    android:valueFrom="0.5"
                    android:valueTo="1.0"
                    android:valueType="floatType" />
                <objectAnimator
                    android:duration="1000"
                    android:propertyName="scaleY"
                    android:valueFrom="0.5"
                    android:valueTo="1.0"
                    android:valueType="floatType" />
                <objectAnimator
                    android:duration="1000"
                    android:propertyName="alpha"
                    android:valueFrom="0.0"
                    android:valueTo="1.0"
                    android:valueType="floatType" />
            </set>
        </aapt:attr>
    </target>
</animated-vector>
