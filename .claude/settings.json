{
  "permissions": {
    "allow": [
      "Bash(bash scripts/setup-hooks.sh)",
      "Bash(bash scripts/run-android-gate.sh)",
      "Bash(bash scripts/pr-pipeline-merge.sh)",
      "Bash(python3 scripts/init_claude_task_context.py:*)",
      "Bash(python3 scripts/android_quality_checks.py:*)",
      "Bash(./gradlew compileDebugKotlin --no-daemon --console=plain)",
      "Bash(./gradlew lintDebug --no-daemon --stacktrace)",
      "Bash(./gradlew testDebugUnitTest --no-daemon --stacktrace)",
      "Bash(./gradlew androidQualityConventions --no-daemon --console=plain)",
      "Bash(./gradlew lintDebug testDebugUnitTest --no-daemon --stacktrace)",
      "Bash(git push)",
      "Bash(git push -u origin:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr merge:*)",
      "Bash(git rev-parse --abbrev-ref HEAD)",
      "Bash(git rev-parse --abbrev-ref --symbolic-full-name @{u})"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/claude_hooks/pre_tool_use.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/claude_hooks/pre_adb_boot_check.py",
            "statusMessage": "Emülatör boot durumu kontrol ediliyor..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/claude_hooks/post_tool_use.py",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/claude_hooks/notification.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/claude_hooks/stop.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/claude_hooks/subagent_start.py"
          }
        ]
      }
    ]
  }
}
